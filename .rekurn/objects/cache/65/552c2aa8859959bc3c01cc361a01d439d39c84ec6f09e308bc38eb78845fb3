From Stdlib Require Import List Bool Arith.PeanoNat Lia.
Import ListNotations.
Require Import ArcTypes ArcMerkle ArcAuthority ArcPolicy ArcVerify ArcSecurityGame ArcTheorems ArcStressProofs ArcDelegationProofs ArcCryptoReduction.

Definition epoch_strictly_advances (from_epoch to_epoch : Epoch) : bool :=
  Nat.ltb from_epoch to_epoch.

Definition rewrap_target_inside_capability_window (cap : Capability) (to_epoch : Epoch) : bool :=
  epoch_in_window to_epoch (cap_epoch_start cap) (cap_epoch_end cap).

Definition rewrap_allowed (cap : Capability) (from_epoch to_epoch : Epoch) : bool :=
  epoch_strictly_advances from_epoch to_epoch &&
  rewrap_target_inside_capability_window cap to_epoch.

Definition temporal_open_allowed (cap : Capability) (obj : ArcObject) : bool :=
  capability_valid_for_object_epoch cap obj.

Definition same_epoch_rewrap_attempt (cap : Capability) (epoch_value : Epoch) : bool :=
  rewrap_allowed cap epoch_value epoch_value.

Definition backward_rewrap_attempt (cap : Capability) (from_epoch to_epoch : Epoch) : bool :=
  Nat.leb to_epoch from_epoch &&
  rewrap_allowed cap from_epoch to_epoch.

Definition early_rewrap_attempt (cap : Capability) (from_epoch to_epoch : Epoch) : bool :=
  Nat.ltb to_epoch (cap_epoch_start cap) &&
  rewrap_allowed cap from_epoch to_epoch.

Definition late_rewrap_attempt (cap : Capability) (from_epoch to_epoch : Epoch) : bool :=
  Nat.ltb (cap_epoch_end cap) to_epoch &&
  rewrap_allowed cap from_epoch to_epoch.

Theorem temporal_same_epoch_rewrap_rejected :
  forall cap e,
    rewrap_allowed cap e e = false.
Proof.
  intros cap e.
  unfold rewrap_allowed.
  unfold epoch_strictly_advances.
  rewrite Nat.ltb_irrefl.
  reflexivity.
Qed.

Theorem temporal_backward_or_same_rewrap_rejected :
  forall cap from_epoch to_epoch,
    to_epoch <= from_epoch ->
    rewrap_allowed cap from_epoch to_epoch = false.
Proof.
  intros cap from_epoch to_epoch H.
  unfold rewrap_allowed.
  unfold epoch_strictly_advances.
  assert (Nat.ltb from_epoch to_epoch = false) as H_ltb.
  { apply Nat.ltb_ge. exact H. }
  rewrite H_ltb.
  reflexivity.
Qed.

Theorem temporal_target_before_capability_window_rejected :
  forall cap from_epoch to_epoch,
    to_epoch < cap_epoch_start cap ->
    rewrap_allowed cap from_epoch to_epoch = false.
Proof.
  intros cap from_epoch to_epoch H.
  unfold rewrap_allowed.
  destruct (epoch_strictly_advances from_epoch to_epoch); simpl.
  - unfold rewrap_target_inside_capability_window.
    unfold epoch_in_window.
    assert (Nat.leb (cap_epoch_start cap) to_epoch = false) as H_before.
    { apply Nat.leb_gt. exact H. }
    rewrite H_before.
    reflexivity.
  - reflexivity.
Qed.

Theorem temporal_target_after_capability_window_rejected :
  forall cap from_epoch to_epoch,
    cap_epoch_end cap < to_epoch ->
    rewrap_allowed cap from_epoch to_epoch = false.
Proof.
  intros cap from_epoch to_epoch H.
  unfold rewrap_allowed.
  destruct (epoch_strictly_advances from_epoch to_epoch); simpl.
  - unfold rewrap_target_inside_capability_window.
    unfold epoch_in_window.
    destruct (Nat.leb (cap_epoch_start cap) to_epoch); simpl.
    + assert (Nat.leb to_epoch (cap_epoch_end cap) = false) as H_after.
      { apply Nat.leb_gt. exact H. }
      rewrite H_after.
      reflexivity.
    + reflexivity.
  - reflexivity.
Qed.

Theorem temporal_same_epoch_attempt_is_false :
  forall cap e,
    same_epoch_rewrap_attempt cap e = false.
Proof.
  intros cap e.
  unfold same_epoch_rewrap_attempt.
  apply temporal_same_epoch_rewrap_rejected.
Qed.

Theorem temporal_backward_attempt_is_false :
  forall cap from_epoch to_epoch,
    backward_rewrap_attempt cap from_epoch to_epoch = true ->
    False.
Proof.
  intros cap from_epoch to_epoch H.
  unfold backward_rewrap_attempt in H.
  apply andb_true_iff in H.
  destruct H as [H_back H_allowed].
  apply Nat.leb_le in H_back.
  pose proof (temporal_backward_or_same_rewrap_rejected cap from_epoch to_epoch H_back) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_early_rewrap_attempt_is_false :
  forall cap from_epoch to_epoch,
    early_rewrap_attempt cap from_epoch to_epoch = true ->
    False.
Proof.
  intros cap from_epoch to_epoch H.
  unfold early_rewrap_attempt in H.
  apply andb_true_iff in H.
  destruct H as [H_early H_allowed].
  apply Nat.ltb_lt in H_early.
  pose proof (temporal_target_before_capability_window_rejected cap from_epoch to_epoch H_early) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_late_rewrap_attempt_is_false :
  forall cap from_epoch to_epoch,
    late_rewrap_attempt cap from_epoch to_epoch = true ->
    False.
Proof.
  intros cap from_epoch to_epoch H.
  unfold late_rewrap_attempt in H.
  apply andb_true_iff in H.
  destruct H as [H_late H_allowed].
  apply Nat.ltb_lt in H_late.
  pose proof (temporal_target_after_capability_window_rejected cap from_epoch to_epoch H_late) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_rewrap_allowed_implies_epoch_advances :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    from_epoch < to_epoch.
Proof.
  intros cap from_epoch to_epoch H.
  unfold rewrap_allowed in H.
  apply andb_true_iff in H.
  destruct H as [H_advance _].
  unfold epoch_strictly_advances in H_advance.
  apply Nat.ltb_lt in H_advance.
  exact H_advance.
Qed.

Theorem temporal_rewrap_allowed_implies_target_inside_window :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    cap_epoch_start cap <= to_epoch /\ to_epoch <= cap_epoch_end cap.
Proof.
  intros cap from_epoch to_epoch H.
  unfold rewrap_allowed in H.
  apply andb_true_iff in H.
  destruct H as [_ H_window].
  unfold rewrap_target_inside_capability_window in H_window.
  apply epoch_in_window_true_bounds.
  exact H_window.
Qed.

Theorem temporal_rewrap_allowed_implies_not_same_epoch :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    from_epoch <> to_epoch.
Proof.
  intros cap from_epoch to_epoch H H_eq.
  subst to_epoch.
  rewrite temporal_same_epoch_rewrap_rejected in H.
  discriminate.
Qed.

Theorem temporal_rewrap_allowed_excludes_backward :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    to_epoch <= from_epoch ->
    False.
Proof.
  intros cap from_epoch to_epoch H_allowed H_back.
  pose proof (temporal_backward_or_same_rewrap_rejected cap from_epoch to_epoch H_back) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_rewrap_allowed_excludes_target_before_window :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    to_epoch < cap_epoch_start cap ->
    False.
Proof.
  intros cap from_epoch to_epoch H_allowed H_before.
  pose proof (temporal_target_before_capability_window_rejected cap from_epoch to_epoch H_before) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_rewrap_allowed_excludes_target_after_window :
  forall cap from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    cap_epoch_end cap < to_epoch ->
    False.
Proof.
  intros cap from_epoch to_epoch H_allowed H_after.
  pose proof (temporal_target_after_capability_window_rejected cap from_epoch to_epoch H_after) as H_rejected.
  rewrite H_rejected in H_allowed.
  discriminate.
Qed.

Theorem temporal_open_allowed_implies_epoch_window :
  forall cap obj,
    temporal_open_allowed cap obj = true ->
    cap_epoch_start cap <= bound_epoch obj /\
    bound_epoch obj <= cap_epoch_end cap.
Proof.
  intros cap obj H.
  unfold temporal_open_allowed in H.
  unfold capability_valid_for_object_epoch in H.
  apply epoch_in_window_true_bounds.
  exact H.
Qed.

Theorem verified_open_implies_temporal_open_allowed :
  forall obj cap state,
    verify_open_context obj cap state = true ->
    temporal_open_allowed cap obj = true.
Proof.
  intros obj cap state H.
  pose proof (verify_open_context_implies_policy_accepts obj cap state H) as H_policy.
  unfold policy_accepts in H_policy.
  repeat rewrite andb_true_iff in H_policy.
  destruct H_policy as [[_ _] H_epoch].
  unfold temporal_open_allowed.
  exact H_epoch.
Qed.

Theorem verified_open_implies_temporal_epoch_window :
  forall obj cap state,
    verify_open_context obj cap state = true ->
    cap_epoch_start cap <= bound_epoch obj /\
    bound_epoch obj <= cap_epoch_end cap.
Proof.
  intros obj cap state H.
  apply temporal_open_allowed_implies_epoch_window.
  apply verified_open_implies_temporal_open_allowed with (state := state).
  exact H.
Qed.

Theorem verified_open_rejects_epoch_before_window :
  forall obj cap state,
    bound_epoch obj < cap_epoch_start cap ->
    verify_open_context obj cap state = false.
Proof.
  intros obj cap state H.
  apply stress_epoch_before_window_blocks_open.
  exact H.
Qed.

Theorem verified_open_rejects_epoch_after_window :
  forall obj cap state,
    cap_epoch_end cap < bound_epoch obj ->
    verify_open_context obj cap state = false.
Proof.
  intros obj cap state H.
  apply stress_epoch_after_window_blocks_open.
  exact H.
Qed.

Theorem verified_open_cannot_be_temporally_early :
  forall obj cap state,
    verify_open_context obj cap state = true ->
    bound_epoch obj < cap_epoch_start cap ->
    False.
Proof.
  intros obj cap state H_open H_early.
  pose proof (verified_open_implies_temporal_epoch_window obj cap state H_open) as [H_start _].
  lia.
Qed.

Theorem verified_open_cannot_be_temporally_late :
  forall obj cap state,
    verify_open_context obj cap state = true ->
    cap_epoch_end cap < bound_epoch obj ->
    False.
Proof.
  intros obj cap state H_open H_late.
  pose proof (verified_open_implies_temporal_epoch_window obj cap state H_open) as [_ H_end].
  lia.
Qed.

Theorem temporal_rewrap_and_verified_open_preserve_capability_window :
  forall obj cap state from_epoch to_epoch,
    rewrap_allowed cap from_epoch to_epoch = true ->
    verify_open_context obj cap state = true ->
    from_epoch < to_epoch /\
    cap_epoch_start cap <= to_epoch /\
    to_epoch <= cap_epoch_end cap /\
    cap_epoch_start cap <= bound_epoch obj /\
    bound_epoch obj <= cap_epoch_end cap.
Proof.
  intros obj cap state from_epoch to_epoch H_rewrap H_open.
  pose proof (temporal_rewrap_allowed_implies_epoch_advances cap from_epoch to_epoch H_rewrap) as H_advance.
  pose proof (temporal_rewrap_allowed_implies_target_inside_window cap from_epoch to_epoch H_rewrap) as [H_to_start H_to_end].
  pose proof (verified_open_implies_temporal_epoch_window obj cap state H_open) as [H_obj_start H_obj_end].
  repeat split; assumption.
Qed.

Theorem temporal_any_rewrap_time_mutation_rejected :
  forall cap from_epoch to_epoch,
    to_epoch <= from_epoch \/
    to_epoch < cap_epoch_start cap \/
    cap_epoch_end cap < to_epoch ->
    rewrap_allowed cap from_epoch to_epoch = false.
Proof.
  intros cap from_epoch to_epoch H.
  destruct H as [H_back | [H_before | H_after]].
  - apply temporal_backward_or_same_rewrap_rejected. exact H_back.
  - apply temporal_target_before_capability_window_rejected. exact H_before.
  - apply temporal_target_after_capability_window_rejected. exact H_after.
Qed.

Theorem temporal_any_verified_open_time_mutation_rejected :
  forall obj cap state,
    bound_epoch obj < cap_epoch_start cap \/
    cap_epoch_end cap < bound_epoch obj ->
    verify_open_context obj cap state = false.
Proof.
  intros obj cap state H.
  destruct H as [H_before | H_after].
  - apply verified_open_rejects_epoch_before_window. exact H_before.
  - apply verified_open_rejects_epoch_after_window. exact H_after.
Qed.
