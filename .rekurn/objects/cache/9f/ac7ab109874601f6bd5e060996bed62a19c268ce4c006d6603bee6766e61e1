mod helpers;

use arc_core::{ArcError, Rights, TemporalPolicy, open, seal};
use helpers::scenario::Scenario;
use helpers::state::sample_state;

#[test]
fn rejects_cross_object_capability_misuse() {
    let s = Scenario::baseline("strict", 42).mismatched_object("different-object.pdf");

    let bad_req = arc_core::OpenRequest {
        object_id: "different-object.pdf".to_string(),
        required_rights: Rights::READ,
        policy_hash: s.req.policy_hash,
        epoch: 42,
    };

    let err = seal(
        &s.keypair.public,
        &s.message,
        &s.cap,
        &s.proof,
        &s.seal_transparency_proof,
        &s.seal_state,
        &bad_req,
        s.temporal_policy.clone(),
    )
    .expect_err("should reject object mismatch");

    assert!(matches!(
        err,
        ArcError::InvalidCapability("object mismatch")
    ));
}

